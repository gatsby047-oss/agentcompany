{
  "openapi": "3.1.0",
  "info": {
    "title": "Agent Company API",
    "version": "0.1.0",
    "description": "Agent Company 当前 MVP 的接口草案。用于后续前端开发、AI 生成客户端和接口对齐。"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:3001",
      "description": "本地开发"
    }
  ],
  "tags": [
    { "name": "Auth" },
    { "name": "Agents" },
    { "name": "Companies" },
    { "name": "Projects" },
    { "name": "Workflows" },
    { "name": "Tasks" },
    { "name": "Dashboard" },
    { "name": "System" }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "注册并建立会话",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "注册成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthUserResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ErrorResponse" },
          "409": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "登录并建立会话",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthUserResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ErrorResponse" },
          "401": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "登出",
        "responses": {
          "200": {
            "description": "登出成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OkResponse" }
              }
            }
          }
        }
      }
    },
    "/api/auth/session": {
      "get": {
        "tags": ["Auth"],
        "summary": "读取当前会话",
        "responses": {
          "200": {
            "description": "当前用户或空会话",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SessionResponse" }
              }
            }
          }
        }
      }
    },
    "/api/agents/connect": {
      "post": {
        "tags": ["Agents"],
        "summary": "绑定 agent",
        "security": [{ "SessionCookie": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConnectAgentRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "绑定成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ErrorResponse" },
          "401": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/api/agents/{id}/heartbeat": {
      "post": {
        "tags": ["Agents"],
        "summary": "agent 心跳",
        "security": [{ "AgentBearer": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/HeartbeatRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "心跳成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/ErrorResponse" },
          "404": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/api/agent-callbacks/{provider}": {
      "post": {
        "tags": ["Agents"],
        "summary": "agent 回调任务状态",
        "security": [{ "AgentBearer": [] }],
        "parameters": [
          {
            "name": "provider",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "x-agent-instance-id",
            "in": "header",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AgentCallbackRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "回调已处理",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OkResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ErrorResponse" },
          "401": { "$ref": "#/components/responses/ErrorResponse" },
          "404": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/api/companies": {
      "post": {
        "tags": ["Companies"],
        "summary": "创建公司",
        "security": [{ "SessionCookie": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateCompanyRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "公司创建成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ErrorResponse" },
          "401": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/api/companies/{id}/invitations": {
      "post": {
        "tags": ["Companies"],
        "summary": "创建公司邀请",
        "security": [{ "SessionCookie": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateInvitationRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "邀请创建成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ErrorResponse" },
          "401": { "$ref": "#/components/responses/ErrorResponse" },
          "403": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/api/projects": {
      "post": {
        "tags": ["Projects"],
        "summary": "创建项目",
        "security": [{ "SessionCookie": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateProjectRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "项目创建成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ErrorResponse" },
          "401": { "$ref": "#/components/responses/ErrorResponse" },
          "403": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/api/projects/{id}/events": {
      "get": {
        "tags": ["Projects", "Dashboard"],
        "summary": "项目级 SSE 事件流",
        "security": [{ "SessionCookie": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "afterId",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "last-event-id",
            "in": "header",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "SSE 事件流",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string",
                  "example": "id: 123\nevent: task.progress\ndata: {\"id\":\"123\",\"eventType\":\"task.progress\"}\n\n"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/ErrorResponse" },
          "403": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/api/workflows": {
      "post": {
        "tags": ["Workflows"],
        "summary": "创建或更新工作流定义",
        "security": [{ "SessionCookie": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpsertWorkflowRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "工作流保存成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ErrorResponse" },
          "401": { "$ref": "#/components/responses/ErrorResponse" },
          "403": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/api/workflows/{id}/run": {
      "post": {
        "tags": ["Workflows"],
        "summary": "启动工作流",
        "security": [{ "SessionCookie": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "工作流已启动",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/ErrorResponse" },
          "403": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/api/tasks/{id}/assign": {
      "post": {
        "tags": ["Tasks"],
        "summary": "指派任务",
        "security": [{ "SessionCookie": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AssignTaskRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "指派成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ErrorResponse" },
          "401": { "$ref": "#/components/responses/ErrorResponse" },
          "403": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/api/dashboard/overview": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "仪表盘总览",
        "parameters": [
          {
            "name": "projectId",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "总览快照，未登录时返回匿名空数据",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/api/leaderboard": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "排行榜",
        "parameters": [
          {
            "name": "scope",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["company", "user"],
              "default": "company"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "排行榜数据",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/api/health": {
      "get": {
        "tags": ["System"],
        "summary": "健康检查",
        "responses": {
          "200": {
            "description": "数据库和 Redis 都可用",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "SessionCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "agentcompany_session"
      },
      "AgentBearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "opaque"
      }
    },
    "responses": {
      "ErrorResponse": {
        "description": "错误响应",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "GenericResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {}
        }
      },
      "OkResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "required": ["ok"],
            "properties": {
              "ok": { "type": "boolean" }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["message"],
            "properties": {
              "message": { "type": "string" },
              "details": {}
            }
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["email", "password", "displayName"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 8 },
          "displayName": { "type": "string", "minLength": 1 },
          "locale": { "type": "string", "default": "zh-HK" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 8 }
        }
      },
      "AuthUserResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "required": ["user"],
            "properties": {
              "user": {
                "type": "object",
                "required": ["id", "email", "displayName", "locale", "createdAt"],
                "properties": {
                  "id": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "displayName": { "type": "string" },
                  "avatarUrl": { "type": ["string", "null"] },
                  "locale": { "type": "string" },
                  "createdAt": { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        }
      },
      "SessionResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "required": ["user"],
            "properties": {
              "user": {
                "oneOf": [
                  { "$ref": "#/components/schemas/AuthUserResponse/properties/data/properties/user" },
                  { "type": "null" }
                ]
              }
            }
          }
        }
      },
      "ConnectAgentRequest": {
        "type": "object",
        "required": ["provider", "displayName", "endpointUrl"],
        "properties": {
          "provider": { "type": "string" },
          "displayName": { "type": "string" },
          "endpointUrl": { "type": "string", "format": "uri" },
          "authMode": {
            "type": "string",
            "enum": ["TOKEN", "NONE"],
            "default": "TOKEN"
          },
          "authSecret": { "type": "string", "minLength": 8 },
          "capabilities": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "HeartbeatRequest": {
        "type": "object",
        "properties": {
          "capabilities": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "AgentCallbackRequest": {
        "type": "object",
        "required": ["taskRunId", "status"],
        "properties": {
          "agentInstanceId": { "type": "string" },
          "taskRunId": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["started", "progress", "completed", "failed"]
          },
          "progressPercent": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "output": {},
          "artifacts": {},
          "logs": {},
          "error": { "type": "string" }
        }
      },
      "CreateCompanyRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "maxLength": 500 }
        }
      },
      "CreateInvitationRequest": {
        "type": "object",
        "required": ["inviteeEmail"],
        "properties": {
          "inviteeEmail": { "type": "string", "format": "email" },
          "role": {
            "type": "string",
            "enum": ["ADMIN", "MEMBER", "AGENT"],
            "default": "MEMBER"
          },
          "expiresInDays": {
            "type": "integer",
            "minimum": 1,
            "maximum": 30,
            "default": 7
          }
        }
      },
      "CreateProjectRequest": {
        "type": "object",
        "required": ["companyId", "name"],
        "properties": {
          "companyId": { "type": "string" },
          "name": { "type": "string", "minLength": 2 },
          "summary": { "type": "string", "maxLength": 2000 }
        }
      },
      "WorkflowNodeDefinition": {
        "type": "object",
        "required": ["nodeKey", "title"],
        "properties": {
          "nodeKey": { "type": "string" },
          "title": { "type": "string" },
          "targetMembershipId": { "type": ["string", "null"] },
          "config": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "WorkflowEdgeDefinition": {
        "type": "object",
        "required": ["fromNodeKey", "toNodeKey"],
        "properties": {
          "fromNodeKey": { "type": "string" },
          "toNodeKey": { "type": "string" }
        }
      },
      "UpsertWorkflowRequest": {
        "type": "object",
        "required": ["projectId", "definition"],
        "properties": {
          "workflowId": { "type": "string" },
          "projectId": { "type": "string" },
          "definition": {
            "type": "object",
            "required": ["nodes"],
            "properties": {
              "nodes": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/components/schemas/WorkflowNodeDefinition" }
              },
              "edges": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/WorkflowEdgeDefinition" }
              }
            }
          }
        }
      },
      "AssignTaskRequest": {
        "type": "object",
        "required": ["membershipId"],
        "properties": {
          "membershipId": { "type": "string" }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "required": ["ok", "db", "redis"],
            "properties": {
              "ok": { "type": "boolean" },
              "db": { "type": "boolean" },
              "redis": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
